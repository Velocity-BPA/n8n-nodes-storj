{
  "name": "n8n-nodes-storj",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Storj decentralized cloud storage providing 10 resources and 40+ operations for S3-compatible storage, access grants, encryption, and file sharing.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-storj.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-storj#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-storj/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "storj",
    "decentralized-storage",
    "cloud-storage",
    "s3-compatible",
    "object-storage",
    "encryption",
    "distributed-storage",
    "blockchain",
    "web3"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/StorjApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Storj/Storj.node.js",
      "dist/nodes/Storj/StorjTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}